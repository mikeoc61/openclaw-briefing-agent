# Local-only personal config for the morning briefing.
# Copy to ~/.openclaw/briefing.env on the host and fill in real values.
# This file (the example) is committed; the real one must never be.
#
# IMPORTANT: this file is `source`d by bash (briefing_parent.sh), so any
# value containing spaces MUST be double-quoted, e.g.:
#   BRIEFING_WEATHER_LABEL="MY TOWN / 830 ft"
# The Python loader (scripts/local_config.py) strips quotes, so quoting
# is always safe. When in doubt, quote.

# Delivery
BRIEFING_EMAIL_TO=you@example.com
BRIEFING_SIGNAL_TARGET=+15555550100

# Home location (weather / sun)
HOME_LAT=20.0000
HOME_LON=-156.0000
HOME_ELEV_M=100
BRIEFING_WEATHER_LABEL="HOME / 100 ft"
# api.weather.gov points for sunrise/sunset (may differ slightly from home)
NWS_POINT=20.0000,-156.0000

# Calendar
# Path to iCloud CalDAV credentials JSON ({"username": ..., "app_password": ...})
CALDAV_CREDS=~/.openclaw/credentials/icloud.json
# Comma-separated calendar names to include (quote if names contain spaces)
CAL_INCLUDE="Family Calendar,Home"
